FROM debian:stable-slim
WORKDIR /srv
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pyftpdlib python3-openssl netcat-openbsd \
    && rm -rf /var/lib/apt/lists/*
COPY docker/live-test/fixtures/share/ /seed/
COPY docker/live-test/certs/ftps.crt /certs/ftps.crt
COPY docker/live-test/certs/ftps.key /certs/ftps.key
COPY docker/live-test/ftps-server.py  /usr/local/bin/ftps-server.py
COPY docker/live-test/ftps-entrypoint.sh /usr/local/bin/ftps-entrypoint.sh
RUN chmod +x /usr/local/bin/ftps-entrypoint.sh
EXPOSE 2121 30000-30009
CMD ["/usr/local/bin/ftps-entrypoint.sh"]
