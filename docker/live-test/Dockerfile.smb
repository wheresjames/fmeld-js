FROM debian:stable-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends samba netcat-openbsd \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -M -s /usr/sbin/nologin demo \
    && mkdir -p /srv/share /run/samba \
    && chown -R demo:demo /srv/share \
    && (echo password; echo password) | smbpasswd -a -s demo

COPY docker/live-test/fixtures/share/ /seed/
COPY docker/live-test/smb.conf /etc/samba/smb.conf
COPY docker/live-test/smb-entrypoint.sh /usr/local/bin/smb-entrypoint.sh

RUN chmod +x /usr/local/bin/smb-entrypoint.sh

EXPOSE 445

CMD ["/usr/local/bin/smb-entrypoint.sh"]
