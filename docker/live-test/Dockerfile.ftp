FROM debian:stable-slim

WORKDIR /srv

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 python3-pyftpdlib netcat-openbsd \
    && rm -rf /var/lib/apt/lists/*

COPY docker/live-test/fixtures/share/ /seed/
COPY docker/live-test/ftp-server.py /usr/local/bin/ftp-server.py
COPY docker/live-test/ftp-entrypoint.sh /usr/local/bin/ftp-entrypoint.sh

RUN chmod +x /usr/local/bin/ftp-entrypoint.sh

EXPOSE 2121 30000-30009

CMD ["/usr/local/bin/ftp-entrypoint.sh"]
